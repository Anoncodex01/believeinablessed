# Server
PORT=8080
NODE_ENV=production
HOST=0.0.0.0

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Frontend URL (HTTPS in production)
FRONTEND_URL=https://www.believeinablessed.com

# Commission
DEFAULT_AFFILIATE_COMMISSION=10

# Snippe (required)
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=
SNIPPE_BASE_URL=https://api.snippe.sh
SNIPPE_WEBHOOK_URL=https://your-api-domain.com/api/snippe/webhook
BACKEND_URL=https://your-api-domain.com
